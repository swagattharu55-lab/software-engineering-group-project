extends layout

block content
  h1= title
  p Browse surplus food shared by the community.

  //- Search and Filter Bar
  div.card(style="margin-bottom: 2rem; background: #e8f5e9; border: 1px solid #c8e6c9;")
    form(action="/listings", method="GET", style="display:flex; gap:1rem; flex-wrap:wrap; align-items:flex-end;")
      div(style="flex:1; min-width:200px;")
        label(for="search", style="font-weight:bold;") Search Food
        br
        input(type="text", name="search", placeholder="e.g. Apples", value=search || '', style="width:100%; box-sizing:border-box; padding:0.5rem; margin-top:0.3rem;")
      div(style="flex:1; min-width:200px;")
        label(for="location", style="font-weight:bold;") Filter by Location
        br
        input(type="text", name="location", placeholder="e.g. City Centre", value=location || '', style="width:100%; box-sizing:border-box; padding:0.5rem; margin-top:0.3rem;")
      div
        button.btn(type="submit", style="padding:0.6rem 1.5rem; background-color:#2e7d32;") Apply Filters

  if listings.length
    div(style="display:grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;")
      each listing in listings
        div.card(style="display:flex; flex-direction:column; padding:0; overflow:hidden;")
          if listing.image_url
            img(src=listing.image_url, alt=listing.title, style="width:100%; height:200px; object-fit:cover;")
          
          div(style="padding:1.5rem;")
            h3(style="margin-top:0;")= listing.title
            span.badge= listing.category_name
            p(style="margin:0.5rem 0;") #{listing.description.substring(0, 60)}...
            p(style="margin: 0.3rem 0; font-size: 0.9em; color:#555;") 📍 <strong>#{listing.location}</strong>
            p(style="margin: 0.3rem 0; font-size: 0.9em; color:#555;") 📦 Qty: #{listing.quantity}
            p(style="margin: 0.3rem 0 1rem 0; font-size: 0.9em;") 📅 Expires: #{new Date(listing.expiry_date).toLocaleDateString()}
            div(style="margin-top: auto;")
              a.btn(href=`/listings/${listing.id}`, style="display:block; text-align:center; background-color:#1976D2;") View Details
  else
    p(style="text-align:center; font-size:1.2rem; color:#666; margin-top:3rem;") No food matches your search criteria.
