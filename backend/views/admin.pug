extends layout

block content
  div.card(style="border-left: 4px solid #f44336;")
    h1(style="color: #d32f2f; margin-top:0;") Admin Dashboard
    p Welcome, Site Administrator. Here you can oversee all platform activity.

  h2(style="margin-top: 2rem;") All Registered Users
  table(style="width:100%; border-collapse:collapse; background:white; text-align:left; border-radius:4px; overflow:hidden;")
    thead(style="background:#f4f4f4;")
      tr
        th(style="padding:1rem; border-bottom:2px solid #ddd;") ID
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Name
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Email
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Role
    tbody
      each u in users
        tr
          td(style="padding:1rem; border-bottom:1px solid #eee;") #{u.id}
          td(style="padding:1rem; border-bottom:1px solid #eee;")
            a(href=`/users/${u.id}`) #{u.name}
          td(style="padding:1rem; border-bottom:1px solid #eee;") #{u.email}
          td(style="padding:1rem; border-bottom:1px solid #eee;")
            if u.role === 'admin'
              span.badge(style="background:#f44336; color:white;") Admin
            else
              span.badge(style="background:#2196F3; color:white;") User

  h2(style="margin-top: 2rem;") All Food Listings
  table(style="width:100%; border-collapse:collapse; background:white; text-align:left; border-radius:4px; overflow:hidden;")
    thead(style="background:#f4f4f4;")
      tr
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Title
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Status
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Owner ID
        th(style="padding:1rem; border-bottom:2px solid #ddd;") Actions
    tbody
      each listing in listings
        tr
          td(style="padding:1rem; border-bottom:1px solid #eee;")
            a(href=`/listings/${listing.id}`) #{listing.title}
          td(style="padding:1rem; border-bottom:1px solid #eee;") 
            span.badge(style="background:#333; color:white;") #{listing.status}
          td(style="padding:1rem; border-bottom:1px solid #eee;") 
            a(href=`/users/${listing.user_id}`) User #{listing.user_id}
          td(style="padding:1rem; border-bottom:1px solid #eee;")
            form(action=`/admin/listings/${listing.id}/delete`, method="POST", style="margin:0;")
              button.btn(type="submit", style="background-color:#f44336; padding:0.3rem 0.6rem; font-size:0.8rem;") Force Delete
