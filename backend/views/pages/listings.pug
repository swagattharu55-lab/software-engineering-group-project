extends ../layout
block content
  div.page-header
    h1 Available Food
    a.btn(href='/listings/new') + Share Food
  div.filter-bar
    a.filter-btn(href='/listings') All
    each cat in categories
      a.filter-btn(href='/listings?category=' + cat.id class=selectedCategory == cat.id.toString() ? 'active' : '')= cat.name
  if listings.length === 0
    p.empty-msg No listings found for this category
  else
    table.listings-table
      thead
        tr
          th Title
          th Description
          th Quantity
          th Expires
          th Category
          th Shared By
          th Action
      tbody
        each listing in listings
          tr
            td= listing.title
            td= listing.description
            td= listing.quantity
            td= new Date(listing.expiry_date).toLocaleDateString()
            td
              if listing.category
                span.tag= listing.category
            td= listing.user_name
            td
              a.btn(href='/listings/' + listing.id) View
    div.listings-grid
      each listing in listings
        div.listing-card(style="overflow: hidden; padding: 0;")
          - var foodImgs = ['https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=600&q=80', 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=600&q=80', 'https://images.unsplash.com/photo-1584472282946-e5040f5ad2b4?auto=format&fit=crop&w=600&q=80', 'https://images.unsplash.com/photo-1610832958506-aa56368176cf?auto=format&fit=crop&w=600&q=80', 'https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=600&q=80']
          img.listing-img(src=foodImgs[listing.id % 5] alt=listing.title style="width: 100%; height: 200px; object-fit: cover; border-bottom: 2px solid #EEE;" )
          div.listing-content(style="padding: 20px;")
            div.listing-header
              h3= listing.title
              span.badge= listing.status
            p= listing.description
            p 📦 Quantity: #{listing.quantity}
            p 📅 Expires: #{new Date(listing.expiry_date).toLocaleDateString()}
            p 
              img.avatar-small-img(src='/img/costmor' + (((listing.user_id - 1) % 4) + 1) + '.jpg' alt=listing.user_name style="width:30px;height:30px;border-radius:50%;vertical-align:middle;margin-right:10px; object-fit:cover;")
              | #{listing.user_name}
            p 📍 #{listing.location}
            if listing.category
              span.tag= listing.category
            a.btn(href='/listings/' + listing.id style="margin-top:15px;display:inline-block;") View Details