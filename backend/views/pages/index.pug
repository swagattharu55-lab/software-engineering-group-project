extends ../layout
block content
  section.hero-split
    div.hero-text-side
      h1 Nourishing communities together
      p FoodShare community meals bring people together for good food and conversation. We serve free, wholesome meals made from food that would have gone to waste, prepared by volunteers and open to everyone. FoodShare is about more than food – we create a cycle of positive change – reducing food waste and hunger, tackling loneliness, supporting mental health and encouraging healthy eating and sustainable living.
      a.btn-crimson(href='https://foodcycle.org.uk/who-we-are/' target='_blank') Who We Are
    div.hero-image-side
      img(src='/img/volunteer_delivery.png' alt='FoodShare Delivery')
  section.stats
    div.stat-card
      h2= userCount
      p Community Members
    div.stat-card
      h2= listingCount
      p Food Listings
    div.stat-card
      h2 0
      p Kg Waste Saved
  section.categories-section
    h2 Browse by Category
    div.categories-grid
      each cat in categories
        a.category-card(href='/listings?category=' + cat.id)
          span= cat.name
  section.features
    div.feature
      h3 🌱 Reduce Waste
      p Share food before it expires
    div.feature
      h3 🤝 Build Community
      p Connect with people nearby
    div.feature
      h3 💚 Completely Free
      p No money involved just sharing