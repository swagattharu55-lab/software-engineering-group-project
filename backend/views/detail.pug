extends layout

block content
  div.card(style="max-width: 800px; margin: 0 auto;")
    if listing.image_url
      img(src=listing.image_url, alt=listing.title, style="width:100%; max-height:400px; object-fit:cover; border-radius:4px; margin-bottom:1rem;")
    
    div(style="display:flex; justify-content:space-between; align-items:center;")
      h1(style="margin-bottom: 0;")= listing.title
      div
        span.badge(style="font-size:1rem;")= listing.category_name
        span.badge(style="font-size:1rem; background-color:#E91E63; margin-left:0.5rem;") 🤖 AI Verified
    
    p.lead(style="font-size: 1.2rem; margin-top: 1rem;")= listing.description
    
    table(style="width: 100%; text-align: left; margin-top: 1.5rem; border-collapse: collapse;")
      tbody
        tr
          th(style="padding:0.5rem 0; border-bottom:1px solid #eee;") Quantity:
          td(style="padding:0.5rem 0; border-bottom:1px solid #eee;") #{listing.quantity}
        tr
          th(style="padding:0.5rem 0; border-bottom:1px solid #eee;") Location:
          td(style="padding:0.5rem 0; border-bottom:1px solid #eee;") #{listing.location}
        tr
          th(style="padding:0.5rem 0; border-bottom:1px solid #eee;") Shared by:
          td(style="padding:0.5rem 0; border-bottom:1px solid #eee;") 
            a(href=`/users/${listing.user_id}`) #{listing.user_name}
        tr
          th(style="padding:0.5rem 0; border-bottom:1px solid #eee;") Expiry Date:
          td(style="padding:0.5rem 0; border-bottom:1px solid #eee; color: #d32f2f; font-weight: bold;") #{new Date(listing.expiry_date).toLocaleDateString()}
        tr
          th(style="padding:0.5rem 0; border-bottom:1px solid #eee;") Posted on:
          td(style="padding:0.5rem 0; border-bottom:1px solid #eee;") #{new Date(listing.created_at).toLocaleDateString()}

    div(style="margin-top: 2rem;")
      h3 📍 Map Location
      iframe(
        width="100%", 
        height="300", 
        frameborder="0", 
        style="border:0; border-radius:4px;",
        src=`https://maps.google.com/maps?q=${encodeURI(listing.location)}&output=embed`,
        allowfullscreen
      )

    div(style="margin-top: 1.5rem; border-top: 1px solid #eee; padding-top: 1.5rem;")
      h3 🔗 Share & Navigation
      p Maximize pickup efficiency and reach using these automated tools.
      a.btn(href=`https://wa.me/?text=Check+out+this+free+food+listing:+${encodeURI('http://localhost:3000/listings/' + listing.id)}`, target="_blank", style="background-color:#25D366; margin-right:0.5rem;") Share on WhatsApp
      a.btn(href=`https://twitter.com/intent/tweet?text=Free+Food:+${encodeURI(listing.title)}&url=${encodeURI('http://localhost:3000/listings/' + listing.id)}`, target="_blank", style="background-color:#1DA1F2; margin-right:0.5rem;") Share on X
      a.btn(href=`https://www.google.com/maps/dir/?api=1&destination=${encodeURI(listing.location)}`, target="_blank", style="background-color:#4285F4;") 🧭 Optimize Pickup Route
        
    div(style="margin-top: 2rem; display:flex; gap: 1rem; flex-wrap:wrap;")
      a.btn(href="/listings", style="background-color:#757575;") Back to Listings
      
      if user 
        if user.id !== listing.user_id
          form(action="/requests/create", method="POST", style="width:100%; margin-top:1rem; padding:1.5rem; background:#f9f9f9; border:1px solid #ccc; border-radius:4px;")
            h3(style="margin-top:0;") Request this Food
            p Send a request to #{listing.user_name} to arrange collection.
            input(type="hidden", name="listing_id", value=listing.id)
            textarea(name="content", rows="3", style="width:100%; box-sizing:border-box; padding:0.5rem; font-family:inherit;", placeholder="Optional message regarding pickup...")
            br
            button.btn(type="submit", style="margin-top:1rem; background-color:#ff9800;") Request Food
        else
          p(style="color:#4CAF50; font-weight:bold; margin-top:1rem; width:100%; padding:1rem; background:#e8f5e9; border-radius:4px;") (This is your listing)
      else
        p(style="margin-top: 1rem; width:100%; padding:1rem; background:#f0f0f0; border-radius:4px;")
          em Please 
          a(href="/login", style="font-weight:bold;") login
          em  to contact the owner and arrange a pickup.
