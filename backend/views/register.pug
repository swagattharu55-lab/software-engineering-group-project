extends layout

block content
  div.card(style="max-width: 500px; margin: 0 auto; margin-top: 2rem;")
    h1 Register
    p Join the community to share and request surplus food!
    if error
      p(style="color: white; background: #f44336; padding: 0.5rem; text-align: center; border-radius: 4px;")= error
    
    form(action="/register", method="POST", style="margin-top: 1rem;")
      div(style="margin-bottom: 1rem;")
        label(for="name", style="font-weight: bold;") Full Name
        br
        input(type="text", name="name", required, style="width: 100%; box-sizing: border-box; padding: 0.5rem; margin-top: 0.5rem;")
      div(style="margin-bottom: 1rem;")
        label(for="email", style="font-weight: bold;") Email Address
        br
        input(type="email", name="email", required, style="width: 100%; box-sizing: border-box; padding: 0.5rem; margin-top: 0.5rem;")
      div(style="margin-bottom: 1rem;")
        label(for="location", style="font-weight: bold;") Location / Area
        br
        input(type="text", name="location", required, style="width: 100%; box-sizing: border-box; padding: 0.5rem; margin-top: 0.5rem;")
      div(style="margin-bottom: 1.5rem;")
        label(for="password", style="font-weight: bold;") Password
        br
        input(type="password", name="password", required, style="width: 100%; box-sizing: border-box; padding: 0.5rem; margin-top: 0.5rem;")
      
      button.btn(type="submit", style="width: 100%; font-size: 1.1rem; padding: 0.75rem;") Create Account
    
    p(style="text-align: center; margin-top: 1.5rem;")
      | Already have an account? 
      a(href="/login", style="color: #4CAF50; font-weight: bold;") Login here
